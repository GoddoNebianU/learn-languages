# ─── Database (PostgreSQL) [必填] ─────────────────────
# PostgreSQL 连接字符串
DATABASE_URL=

# ─── Auth (better-auth) [必填] ─────────────────────────
# JWT 签名密钥 (可用 openssl rand -hex 32 生成)
BETTER_AUTH_SECRET=
# Auth 服务 URL, 生产环境设为实际域名 (如 https://example.com), 留空则使用当前域名
BETTER_AUTH_URL=
# ─── Admin [必填] ───────────────────────────────────────
# 管理后台登录密码 (用于 /admin 页面)
ADMIN_PASSWORD=

# ─── System Config ──────────────────────────────────────
# 功能开关和服务配置存储在数据库 (system_config 表，单行)
# 使用 seed 脚本初始化:
#   npx tsx scripts/seed-capabilities.ts
#
# 由 DB 管理的配置项:
#   - LLM API Key / URL / 模型名
#   - TTS primary 接口配置 (URL / 用户名 / 密码)
#   - SMTP 配置
#   - 功能开关 (signup, userProfile, social, email - 默认全部启用)

# ─── Node ───────────────────────────────────────────────
# 开发环境 HTTPS 需要关闭 TLS 验证
# NODE_TLS_REJECT_UNAUTHORIZED=0
