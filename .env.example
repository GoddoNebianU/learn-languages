# ─── Database (PostgreSQL) [必填] ─────────────────────
# PostgreSQL 连接字符串
DATABASE_URL=

# ─── Auth (better-auth) [必填] ─────────────────────────
# JWT 签名密钥 (可用 openssl rand -hex 32 生成)
BETTER_AUTH_SECRET=
# Auth 服务 URL, 生产环境设为实际域名 (如 https://example.com), 留空则使用当前域名
BETTER_AUTH_URL=
# ─── Admin [必填] ───────────────────────────────────────
# 管理后台登录密码 (用于 /admin 页面)
ADMIN_PASSWORD=

# ─── System Config ──────────────────────────────────────
# 功能开关和服务配置已迁移到数据库 (system_config + tier_capabilities 表)
# 使用 seed 脚本初始化:
#   npx tsx scripts/seed-capabilities.ts --tier=SINGLE  (个人模式)
#   npx tsx scripts/seed-capabilities.ts --tier=MULTI   (多用户模式)
#
# 迁移后由 DB 管理的配置项:
#   - 部署层级 (SINGLE/MULTI)
#   - LLM API Key / URL / 模型名
#   - TTS API Key
#   - SMTP 配置
#   - 功能开关 (signup, userProfile, social, email)

# ─── Node ───────────────────────────────────────────────
# 开发环境 HTTPS 需要关闭 TLS 验证
# NODE_TLS_REJECT_UNAUTHORIZED=0
