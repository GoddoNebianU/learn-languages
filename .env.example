# ─── LLM (智谱 AI) ─────────────────────────────────────
# 智谱 AI API Key, 用于翻译、词典、OCR 等 AI 功能
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=
# 模型名称, 如 glm-4-flash
ZHIPU_MODEL_NAME=
# API 地址, 如 https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_URL=

# ─── Auth (better-auth) ────────────────────────────────
# JWT 签名密钥, 生产环境必须设置 (可用 openssl rand -hex 32 生成)
BETTER_AUTH_SECRET=
# Auth 服务 URL, 生产环境设为实际域名 (如 https://example.com), 留空则使用当前域名
BETTER_AUTH_URL=
# 认证模式: multi (多用户, 默认) | single (单用户, 跳过登录, 自动创建 admin 用户)
NEXT_PUBLIC_AUTH_MODE=

# ─── Database (PostgreSQL) ─────────────────────────────
# PostgreSQL 连接字符串, 格式: postgresql://user:password@host:port/database
DATABASE_URL=

# ─── DashScore (阿里云百炼) ────────────────────────────
# 阿里云 DashScope API Key, 用于 TTS 语音合成 (qwen3-tts-flash)
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCORE_API_KEY=

# ─── SMTP Email (Resend) ──────────────────────────────
# 用于发送验证邮件和密码重置邮件
# 注册地址: https://resend.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
# Resend API Key, 在 Resend 控制台获取
SMTP_PASS=re_your_resend_api_key
# 发件人地址, 需在 Resend 中验证域名或使用默认的 resend.dev
SMTP_FROM=onboarding@resend.dev
