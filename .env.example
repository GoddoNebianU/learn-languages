# ─── Database (PostgreSQL) [必填] ─────────────────────
# PostgreSQL 连接字符串
# 格式: postgresql://user:password@host:port/database
DATABASE_URL=

# ─── Auth (better-auth) [必填] ─────────────────────────
# JWT 签名密钥 (可用 openssl rand -hex 32 生成)
BETTER_AUTH_SECRET=
# Auth 服务 URL, 生产环境设为实际域名 (如 https://example.com), 留空则使用当前域名
BETTER_AUTH_URL=
# 认证模式: multi (多用户, 默认) | single (单用户, 跳过登录, 自动创建 admin 用户)
NEXT_PUBLIC_AUTH_MODE=

# ─── SMTP Email ────────────────────────────────────────
# 用于发送验证邮件和密码重置邮件
# multi 模式必填, single 模式可留空 (无注册/找回密码功能)
SMTP_HOST=smtp.resend.com
# 端口, 默认 587
SMTP_PORT=587
# 是否使用 SSL, 可选: true | false, 默认 false
SMTP_SECURE=false
SMTP_USER=resend
# Resend API Key, 在 Resend 控制台获取
SMTP_PASS=re_your_resend_api_key
# 发件人地址, 需在 Resend 中验证域名或使用默认的 resend.dev, 留空则使用 SMTP_USER
SMTP_FROM=onboarding@resend.dev

# ─── LLM (智谱 AI) [按需] ─────────────────────────────
# 智谱 AI API Key, 使用翻译/词典/OCR 时必填
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=
# 模型名称, 默认 glm-4.6
ZHIPU_MODEL_NAME=
# API 地址, 默认 https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPU_API_URL=

# ─── TTS (阿里云百炼) [按需] ──────────────────────────
# 阿里云 DashScope API Key, 使用语音合成时必填
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCORE_API_KEY=
